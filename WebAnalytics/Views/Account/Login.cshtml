@using Domain.Requests;
@model DTOIMLoginRequest
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Page</title>
  
    <link href="~/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/sweetalert2/sweetalert2.min.js"></script>
    <link href="~/css/login.css" rel="stylesheet" />
    <script src="~/js/crypto-js.min.js"></script>

</head>

<body>

    <div class="login-card text-center">
        <div class="company__logo">
            <i class="fa fa-android"></i>
        </div>

        <img src="~/images/logo.png" width="300px" />
        <h5 class="mb-3 text-white">Log In</h5>
        <form asp-action="Login" asp-controller="Account" method="post" novalidate>
            <input type="hidden" id="aesKey" value="@ViewBag.hdns" />
            @Html.AntiForgeryToken()
            <div class="mb-3 text-start">
                <label asp-for="UserName" class="form-label text-white"></label>
                <input asp-for="UserName" class="form__input form-control" value="@Model.UserName" required />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>

            <div class="mb-3 text-start">
                <label asp-for="Password" class="form-label text-white"></label>
                <input asp-for="Password" class="form__input form-control"  required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-login">Submit</button>
        </form>
        <div class="text-start mb-2">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        </div>
    </div>

    <script src="~/developerjs/login.js"></script>

</body>
</html>
