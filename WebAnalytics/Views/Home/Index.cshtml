
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
}

<script src="~/js/chart.js"></script>
<script src="~/js/chartjs-plugin-datalabels.js"></script>
<link href="~/css/home.css" rel="stylesheet" />
<link href="~/css/timeline.css" rel="stylesheet" />
<div class="container">


    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>DGIS Analytics</span>
            <!-- Dropdown on the right side -->
            <div class="d-flex justify-content-between align-items-center">

                <div class="d-flex gap-2">
                    <select class="form-select w-auto" aria-label="Default select example" id="ddlappliction">
                    </select>
                    @{
                        var currentYear = DateTime.Now.Year;
                        var years = Enumerable.Range(currentYear - 4, 5).Reverse();
                    }

                    <select id="ddlYears" name="year" class="form-select w-auto " aria-label="Default select example">
                        @foreach (var year in years)
                        {
                            <option value="@year">@year</option>
                        }
                    </select>


                    @{
                        var currentMonth = DateTime.Now.Month;

                        var months = Enumerable.Range(1, 12)
                        .Select(m => new
                        {
                            Value = m,
                            Name = new DateTime(2000, m, 1).ToString("MMMM")
                        })
                        .Reverse(); // Dec → Jan
                    }

                    <select id="ddlMonths" name="month" class="form-select w-auto" aria-label="Select month">
                        @foreach (var month in months)
                        {
                            <option value="@month.Value"
                                    selected="@(month.Value == currentMonth)">
                                @month.Name
                            </option>
                        }
                    </select>

                </div>
            </div>

        </div>
        <div class="card-body">
            <div class="dashboard">

                <div>
                    <div class="newprojectheading text-left"> <span>Concurrent Users</span> </div>
                    <div class="chart-box">

                        <!-- Vertical Bar Chart -->
                        <canvas id="barChartForConcurrentuser"></canvas>
                    </div>
                </div>
                <div>
                    <div class="newprojectheading text-center">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>  Daily Hit Counts</span>

                        </div>

                    </div>
                    <div class="chart-box">

                        <!-- Line Chart -->
                        <canvas id="lineChartDays"></canvas>
                    </div>
                </div>

                <div>
                    <div class="newprojectheading text-center">
                        <div class="d-flex justify-content-between align-items-center">
                            <span> Monthly Hit Counts</span>

                        </div>

                    </div>
                    <div class="chart-box">

                        <!-- Line Chart -->
                        <canvas id="lineChart"></canvas>
                    </div>
                </div>
                <div>
                    <div class="newprojectheading text-left"> <span>Total Counts</span> </div>
                    <div class="chart-box">

                        <!-- Vertical Bar Chart -->
                        <canvas id="barChart"></canvas>
                    </div>
                </div>

            </div>

        </div>
    </div>


</div>
<script src="~/developerjs/analytics.js"></script>
